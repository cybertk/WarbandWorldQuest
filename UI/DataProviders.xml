<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\..\..\..\..\WoW\Data\Interface\AddOns\Blizzard_SharedXML\UI.xsd">
    <Script file="QuestDataProvider.lua" />
    <Script file="MapCanvasDataProvider.lua" />

    <Button name="WarbandWorldQuestPinTemplate" inherits="WorldQuestPinTemplate" flattenRenderLayers="true" enableMouse="true" mixin="WarbandWorldQuestPinMixin" virtual="true">
        <Layers>
            <Layer level="OVERLAY">
                <Texture parentKey="CompletedIndicator" atlas="common-icon-checkmark">
                    <Size x="14" y="14" />
                    <Anchors>
                        <Anchor point="BOTTOM" relativePoint="BOTTOMRIGHT" x="0" y="-2" />
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Scripts>
            <OnEnter method="OnMouseEnter" />
            <OnLeave method="OnMouseLeave" />
            <OnClick method="OnClick" />
        </Scripts>
    </Button>

    <!-- from Blizzard_GameTooltip/Mainline/GameTooltip.xml -->
    <GameTooltip name="WarbandWorldQuestShoppingTooltip1" clampedToScreen="true" frameStrata="TOOLTIP" hidden="true" parent="UIParent" inherits="ShoppingTooltipTemplate" />
    <GameTooltip name="WarbandWorldQuestShoppingTooltip2" clampedToScreen="true" frameStrata="TOOLTIP" hidden="true" parent="UIParent" inherits="ShoppingTooltipTemplate" />
    <GameTooltip name="WarbandWorldQuestGameTooltip" inherits="GameTooltipTemplate" parent="UIParent">
        <KeyValues>
            <KeyValue key="supportsItemComparison" value="true" type="boolean" />
        </KeyValues>
        <Frames>
            <Frame parentKey="ItemTooltip" inherits="InternalEmbeddedItemTooltipTemplate" hidden="true">
                <Size x="100" y="100" />
                <Anchors>
                    <Anchor point="BOTTOMLEFT" relativePoint="BOTTOMLEFT" x="10" y="13" />
                </Anchors>
                <KeyValues>
                    <KeyValue key="yspacing" value="13" type="number" />
                </KeyValues>
                <Scripts>
                    <OnLoad inherit="prepend">
                        self.Tooltip.shoppingTooltips = { WarbandWorldQuestShoppingTooltip1, WarbandWorldQuestShoppingTooltip2 };
                    </OnLoad>
                </Scripts>
            </Frame>
        </Frames>
        <Scripts>
            <OnLoad method="OnLoad" />
            <OnShow function="GameTooltip_OnShow" />
            <OnUpdate function="GameTooltip_OnUpdate" />
        </Scripts>
    </GameTooltip>
</Ui>